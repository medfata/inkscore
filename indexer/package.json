{
  "name": "ink-indexer",
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:v2": "node dist/index-v2.js",
    "dev": "tsx watch src/index.ts",
    "dev:v2": "tsx watch src/index-v2.ts",
    "db:migrate": "node dist/db/migrate.js",
    "db:migrate:v2": "node dist/db/migrate-v2.js"
  },
  "dependencies": {
    "viem": "^2.21.0",
    "pg": "^8.13.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}